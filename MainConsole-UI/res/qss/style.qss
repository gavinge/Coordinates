/*表格的一种美化方式*/
/*----------------------------------------------------------------------------------*/
/*----------------------------------------------------------------------------------*/
QHeaderView
{
    background:transparent;
}

QHeaderView::section
{
    font-family:"Microsoft YaHei";
    color:black;
    border: 1px solid rgba(200, 200, 200, 50%);
    border-right: none;
    border-left: none;
    font-size: 7pt;
    background:white;
    text-align:left;
    margin-left:0px;
    padding-left:0px;
    font-weight: bold; /* 设置字体加粗 */
    min-height:38px;
    max-height:38px;
}

QTableWidget
{
    background:#FFFFFF;
    font-family:"Microsoft YaHei";
    font-size:16px;
    color:#666666;
    outline:none;
    border: none;
}
QTableWidget::item
{
        border-bottom: none;
        color:black;
        height:38px;
        border-right: none;
}

QTableWidget::item:hover {
        background-color: #EFEFEF;  /* 选中行的背景颜色 */
}
QTableWidget::item::selected
{

    background-color: #E5F3FF;
    color: black;  /* 选中行的文本颜色 */
    border-style: dotted;
    border-width: 0.3px;
}
QTableView::item:alternate
{
    background-color: lightblue;
}
/*
QTableView::item:selected:!active{
        background-color:#f0f0f2;
}*/




QTableWidget::indicator {
    width: 68px; /* 宽度 */
    height: 25px; /* 高度 */
}

QTableWidget::indicator:checked {
    image: url(:/res/image/customRule/enable_rule.png); /* 选中状态图标的路径 */
}

QTableWidget::indicator:unchecked {
    image: url(:/res/image/customRule/disable_rule.png); /* 未选中状态图标的路径 */
}
