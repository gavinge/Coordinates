/**全局属性**/
/*--------------------------------------------------------------------------*/
QLabel {
    font-family: "Microsoft YaHei";
    color: white;
    /*src: url(":/path/to/MicrosoftYaHei.ttf"); */
}




QToolButton {
    font-family: "Microsoft YaHei";
}

QPushButton {
    font-family: "Microsoft YaHei";
}


QMenu {
    background-color: #F5F5F5;
    font-family: "Microsoft YaHei";
    font-size: 14px;
    /*margin: 2px;*/ /* some spacing around the menu */
    border: 0.5px solid gray;

}

QMenu::item {
    padding: 2px 25px 2px 5px;
    border: 1px solid transparent; /* reserve space for selection border */
    height: 22;
}

QMenu::item:selected {
    border-color: gray;
    background: #F6FFEA;
}

QMenu::icon {
    padding-left: 10px;
}


QMenu::icon:checked { /* appearance of a 'checked' icon */
    background: gray;
    border: 1px inset gray;
    position: absolute;
    top: 1px;
    right: 1px;
    bottom: 1px;
    left: 1px;
}

QMenu::separator {
    height: 2px;
    background: #808080;
    margin-left: 10px;
    margin-right: 5px;
}

QMenu::indicator {
    width: 13px;
    height: 13px;
}
/*--------------------------------------------------------------------------*/




/**toobar相关属性**/
/*--------------------------------------------------------------------------*/
#topWidget {
    background-image: url(:/res/image/main/tab/toolbar_bkg.png);
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    background-color: rgba(255, 255, 255, 255);
}

#Widget {
    /*background: qlineargradient(x1:0, y1:0, x2:1, y2:0, stop:0 #FFFFFF, stop:1 #A5E9CA);background-color:  #EEFBF3; #D7E9F3;*/
    /*background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #E4F0DC, stop:1 #D7E9F3);*/
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #E4F0DC, stop:1 #D7E9F3);
}
*[mainwindow_toolbutton="true"] {
    border: 0px;
    border-radius: 0px;
    background-color: #00000000;
    color:rgb(255, 255, 255);

}

/* 菜单栏按下时 */
*[mainwindow_toolbutton_selected="true"] { /* italicize selected tabs */
    /*background-color: qlineargradient(x1:0, y1:0, x2:0, y2:1,
    stop:0 rgba(0, 0, 0, 0),
    stop:1 rgba(0, 0, 0, 32));*/
    background-image: url(:/res/image/main/tab/toobar_bkg.png);
    background-repeat: no-repeat;
    background-position: center bottom;
}


