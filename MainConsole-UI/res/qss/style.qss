/**title-caption 相关属性**/
/*--------------------------------------------------------------------------*/

#titleWidget QPushButton {
    background-color: transparent;
    border: none;
    padding: 0;
    margin: 0;
}

#titleWidget QPushButton#titlePushButton {
    background-image: url(:/res/image/main/title/title.png) left center no-repeat;
    background-repeat: no-repeat;
    padding-left: 20px;
}


#titleWidget QPushButton#minPushButton {
    background-image: url(:/res/image/main/title/title_min_btn.png);
    background-repeat: no-repeat;
    background-position: center;

}
#titleWidget QPushButton#closePushButton:hover {
    background-color: rgba(255, 0, 0, 0.9);
}

#titleWidget QPushButton#closePushButton:pressed {
    background-color: rgba(139, 0, 0, 0.9);
}


#titleWidget QPushButton#closePushButton {
    background-image: url(:/res/image/main/title/title_close_btn.png);
    background-repeat: no-repeat;
    background-position: center;
}
#titleWidget QPushButton#minPushButton:hover {
    background-color: rgba(255, 255, 255, 0.2);
}

#titleWidget QPushButton#minPushButton:pressed {
    background-color: rgba(255, 255, 255, 0.4);
}


#titleWidget QPushButton#titleUpdate {
    background-image: url(:/res/image/main/title/update.png);
    background-repeat: no-repeat;
    background-position: 0 5;
}
#titleWidget QPushButton#titleUpdate:hover {
    background-color: rgba(255, 255, 255, 0.2);
}

#titleWidget QPushButton#titleUpdate:pressed {
    background-color: rgba(255, 255, 255, 0.4);
}


