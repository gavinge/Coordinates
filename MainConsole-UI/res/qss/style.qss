    color: black;
}


#AgentManWidget QPushButton { background-color: #649B17; color: white; border: none; border-radius: 3px;}
#AgentManWidget QPushButton:hover { background-color: #52870E; color: white;}
#AgentManWidget QPushButton:pressed { background-color: #496D0C;color: white; }

#AgentManWidget QCheckBox {
    spacing: 5px; /* 设置QCheckBox的文字和框之间的间距 */
    color: #404040;
}
#AgentManWidget QCheckBox::indicator {
    image: url(:/res/image/agentMan/chk_uncheck.png); /* 未选中状态的背景图 */
}
#AgentManWidget QCheckBox::indicator:checked {
    image: url(:/res/image/agentMan/chk_check.png); /* 选中状态的背景图 */
}

/* 标签样式 */
#AgentManCustomListWidgetItem QLabel {
    color: #404040;
}

#AgentManWidget QLabel {
    color: black;
}

QPushButton#researchPushButton {
    background-image: url(:/res/image/agentMan/query.png);
    border: none;
    background-repeat: no-repeat;
    background-position: center;
}

QPushButton#researchPushButton:hover {
    background-color: #408C30;
}

QPushButton#researchPushButton:pressed {
    background-color: #205C1F;
}



/* 单选按钮样式 */
#AgentManCustomListWidgetItem QRadioButton {
    spacing: 5px; /* 设置QRadioButton的文字和框之间的间距 */
}
#AgentManCustomListWidgetItem QRadioButton::indicator {
    image: url(:/res/image/agentMan/rdbtn_unselected.png); /* 未选中状态的背景图 */
}
#AgentManCustomListWidgetItem QRadioButton::indicator:checked {
    image: url(:/res/image/agentMan/rdbtn_selected.png); /* 选中状态的背景图 */
}

#AgentManCustomListWidgetItem QListWidget::item:hover, QListWidget::item:selected {
    background-color: #F6FFEA /* 设置鼠标移动或选中时的背景色 */
}
/*----------------------------------------------------------------------------------*/


/**QListWidget样式**/
/*----------------------------------------------------------------------------------*/
#groupListWidget::item:hover{
    background-color: #EFEFEF; /* 设置鼠标移动或选中时的背景色 */
    border-left: 3px solid #DFDFDF;
}
#groupListWidget::item:selected {
    background-color: #6ED01C; /* 设置鼠标移动或选中时的背景色 */
    color:white;
    border: none;
     border-left: 3px solid #006400;
}
#groupListWidget::item {
    width: 150x; height: 37px;
}
#groupListWidget::focus {
    border: none;
    outline: none;
}

QListWidget::item:hover{
    background-color: #EFEFEF /* 设置鼠标移动或选中时的背景色 */
}
QListWidget::item:selected {
    background-color: #E5F3FF; /* #96E427设置鼠标移动或选中时的背景色 */
    color:white;
    border: none;
}
QListWidget::item {
    width: 150x;
    height: 37px;
}
QListWidget::focus {
    border: none;
    outline: none;
}
